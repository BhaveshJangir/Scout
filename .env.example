# Required
OPENAI_API_KEY=sk-replace-me

# Model + cost knobs
OPENAI_MODEL=gpt-4o-mini
# Cost per 1K tokens (USD). Update if you change model.
COST_INPUT_PER_1K=0.00015
COST_OUTPUT_PER_1K=0.0006

# Agent guardrails
MAX_ITERATIONS=8
MAX_WALL_TIME_S=120
MAX_COST_USD=0.50
LLM_TIMEOUT_S=60
TOOL_TIMEOUT_S=15

# HTTP server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Storage
DB_PATH=./runs.db
